# ─────────────────────────────────────────────────────────
# LavaMusic — environment configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# Bot credentials
TOKEN=""                           # Your Discord bot token
CLIENT_ID=""                       # Your bot's client/application ID

# Behaviour
DEFAULT_LANGUAGE="en-US"           # Default locale (e.g. en-US, de, fr)
PREFIX="!"                         # Prefix for text commands
BOT_STATUS="online"                # online | idle | dnd | invisible
BOT_ACTIVITY_TYPE=0                # 0=Playing 1=Streaming 2=Listening 3=Watching 5=Competing
BOT_ACTIVITY="Lavamusic"           # Activity text shown under the bot name

# Owners & guild
OWNER_IDS=[""]                     # Discord user IDs of bot owners (JSON array)
GUILD_ID=""                        # Lock slash commands to one guild (leave blank for global)

# Database
# SQLite (default, no extra setup needed):
DATABASE_URL="file:./lavamusic.db"
# PGLite (embedded Postgres, persistent file):
# DATABASE_URL="file:./lavamusic-pgdata"
# External Postgres (use --profile postgres in compose or point to your server):
# DATABASE_URL="postgresql://lavamusic:lavamusic@postgres:5432/lavamusic"

# Search engine used when a plain query is given (not a URL)
# Options: youtube | youtubemusic | soundcloud | spotify | apple | deezer | yandex | jiosaavn
SEARCH_ENGINE="youtubemusic"

# ─────────────────────────────────────────────────────────
# Lavalink nodes
#
# The bot does NOT connect to these on startup — it connects
# on the first play command, then disconnects after 10 min
# of inactivity and reconnects on the next request.
#
# List as many public or private nodes as you like.
# The bot will use the least-loaded connected node and
# will try all listed nodes if one is unreachable.
#
# Each node object supports:
#   id              — display name (any string)
#   host            — hostname or IP
#   port            — port number
#   authorization   — password
#   secure          — true for wss/https, false for ws/http
#   retryAmount     — how many reconnect attempts before giving up (default: 5)
#   retryDelay      — ms between reconnect attempts (default: 30000)
#
# Example with multiple public nodes:
# ─────────────────────────────────────────────────────────
NODES=[
  {"id":"Node1","host":"lavalink.example.com","port":443,"authorization":"yourpassword","secure":true},
  {"id":"Node2","host":"lavalink2.example.com","port":2333,"authorization":"yourpassword","secure":false,"retryAmount":3,"retryDelay":30000}
]

# Optional integrations
TOPGG=""                           # Top.gg API token (for vote tracking)
KEEP_ALIVE="false"                 # Set true when hosting on Replit
LOG_CHANNEL_ID=""                  # Channel to post node connect/disconnect logs
LOG_COMMANDS_ID=""                 # Channel to post command usage logs
GENIUS_API=""                      # Genius API client token (for /lyrics)
